    /* ── Admin: delete a record (with confirmation) ──────────────────── */
    async function admDeleteRecord(orderId){
      var rec = admRecs.find(function(x){return x.orderId===orderId;});
      if(!rec){ alert('Record not found.'); return; }
      var label = (rec.name||'—') + ' · ' + (rec.module||'—') + ' · ' + (rec.invoiceNo||rec.orderId);
      if(!confirm('Permanently delete this record from GitHub?\n\n' + label + '\n\nThis cannot be undone.')) return;
      try {
        var gh = await admGhRead();
        var idx = (gh.records||[]).findIndex(function(x){return x.orderId===orderId;});
        if(idx < 0){ alert('Record not on server. Refreshing list.'); admRefresh(); return; }
        gh.records.splice(idx, 1);
        var w = await fetch(ADM_API,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({records:gh.records, sha:gh.sha, message:'admin: delete '+orderId})});
        if(!w.ok) throw new Error('GitHub write failed: '+w.status);
        admRecs = admRecs.filter(function(x){return x.orderId!==orderId;});
        admRender();
      } catch(e){
        console.error('Delete failed:', e);
        alert('Delete failed: '+(e.message||'unknown error'));
      }
    }

    /* ── Admin: One-click migration to renumber confirmed invoices ──────── */
    async function admMigrateInvoiceNos(){
      var msg = 'This will renumber every CONFIRMED invoice to the new FOB####### sequence (sorted by confirmed date) and reset the counter.\n\n' +
                'Existing invoice numbers are preserved as legacyInvoiceNo on each record.\n\n' +
                'Continue?';
      if(!confirm(msg)) return;
      try {
        var gh = await admGhRead();
        var allRecs = gh.records || [];
        /* Sort confirmed records by confirmedAt ascending; fall back to initiatedAt */
        var confirmedRecs = allRecs.filter(function(r){return r.status==='confirmed';})
          .sort(function(a,b){
            var da = new Date(a.confirmedAt||a.initiatedAt||0).getTime();
            var db = new Date(b.confirmedAt||b.initiatedAt||0).getTime();
            return da - db;
          });
        if(!confirmedRecs.length){ alert('No confirmed records to renumber.'); return; }
        var changed = 0;
        confirmedRecs.forEach(function(r, i){
          var newNo = 'FOB' + String(i+1).padStart(7, '0');
          if(r.invoiceNo && r.invoiceNo !== newNo){
            if(!r.legacyInvoiceNo) r.legacyInvoiceNo = r.invoiceNo;
            r.invoiceNo = newNo;
            r.invoiceMigratedAt = new Date().toISOString();
            changed++;
          } else if(!r.invoiceNo){
            r.invoiceNo = newNo;
            r.invoiceMigratedAt = new Date().toISOString();
            changed++;
          }
        });
        /* Persist updated records */
        var w = await fetch(ADM_API,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({records:allRecs,sha:gh.sha,message:'invoice-migration: renumbered '+confirmedRecs.length+' confirmed invoices (changed '+changed+')'})});
        if(!w.ok){throw new Error('GitHub write failed: '+w.status);}
        /* Reset the counter so the next confirmed payment continues the sequence */
        try {
          await fetch('/api/invoice-counter',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({counter: confirmedRecs.length})});
        } catch(e){ console.warn('Counter set failed, but records updated:', e); }
        alert('✅ Renumbered ' + confirmedRecs.length + ' confirmed invoice(s).\nNext payment will be FOB' + String(confirmedRecs.length+1).padStart(7,'0') + '.');
        admRefresh();
      } catch(e){
        console.error('Migration failed:', e);
        alert('Migration failed: '+(e.message||'unknown error'));
      }
    }

