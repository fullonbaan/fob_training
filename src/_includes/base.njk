  <!-- jsPDF + AutoTable for GST Invoice generation (admin panel + pricing page) -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.6.0/jspdf.plugin.autotable.min.js"></script>

  <!-- Defer: EmailJS (only needed on pricing/contact pages) -->
  <script defer src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
  <script>
    var EMAILJS_PUBLIC_KEY = '3U-YZo2UCV_RG5Gjo';
    var EMAILJS_SERVICE_ID = 'service_t9cqgtn';
    var EMAILJS_TEMPLATE_ID = 'template_ezdle7f';
  </script>

  {% block head %}{% endblock %}

  <style>
    * { box-sizing: border-box; }
    body { font-family: "Work Sans", sans-serif; }
    .font-headline { font-family: "Noto Serif", serif; }
    .font-label { font-family: "Inter", sans-serif; }

    .glass-nav {
      background: rgba(6, 19, 42, 0.92);
      /* backdrop-filter: blur(20px) removed — causes repaint every scroll frame.
         Increased opacity to 0.92 for equivalent visual depth without GPU cost. */
      will-change: transform;         /* promote to own GPU layer */
      -webkit-backface-visibility: hidden;
      backface-visibility: hidden;
    }

    .editorial-gradient {
      background: linear-gradient(135deg, #f6bc68 0%, #ba8738 100%);
    }

    .text-gradient {
      background: linear-gradient(135deg, #f6bc68 0%, #ba8738 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* scroll-behavior: smooth removed from body — it causes "wavering" feel
       during manual scrolling. Only apply smooth to programmatic scrolls. */
    .smooth-scroll { /* scroll-behavior: auto (default) */ }

    .hamburger { cursor: pointer; }
    .hamburger span {
      display: block;
      width: 25px;
      height: 3px;
      background: #f6bc68;
      margin: 5px 0;
      transition: 0.3s;
    }
    .hamburger.active span:nth-child(1) { transform: rotate(-45deg) translate(-5px, 6px); }
    .hamburger.active span:nth-child(2) { opacity: 0; }
    .hamburger.active span:nth-child(3) { transform: rotate(45deg) translate(-5px, -6px); }

    .mobile-menu {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease-out;
    }
    .mobile-menu.active { max-height: 300px; }

    .nav-link {
      position: relative;
      transition: color 0.3s;
    }
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -5px;
      left: 0;
      width: 0;
      height: 2px;
      background: #f6bc68;
      transition: width 0.3s;
    }
    .nav-link:hover::after { width: 100%; }
    .nav-link.active { color: #f6bc68; }

    /* === Ecosystem Dropdown === */
    .eco-dropdown { position: relative; }
    .eco-dropdown-btn {
      display: flex; align-items: center; gap: 4px;
      color: inherit; background: none; border: none;
      font-size: inherit; font-family: inherit; cursor: pointer;
      padding: 0; position: relative;
      transition: color 0.3s;
    }
    .eco-dropdown-btn::after {
      content: '';
      position: absolute;
      bottom: -5px; left: 0;
      width: 0; height: 2px;
      background: #f6bc68;
      transition: width 0.3s;
    }
    .eco-dropdown:hover .eco-dropdown-btn::after { width: 100%; }
    .eco-dropdown:hover .eco-dropdown-btn { color: #f6bc68; }
    .eco-dropdown-btn .eco-arrow { font-size: 14px; transition: transform 0.2s; }
    .eco-dropdown:hover .eco-arrow { transform: rotate(180deg); }
    .eco-panel {
      position: absolute; top: calc(100% + 18px); left: 50%;
      transform: translateX(-50%);
      background: rgba(9,19,38,0.98);
      /* backdrop-filter removed for perf */
      border: 1px solid rgba(246,188,104,0.15);
      border-radius: 16px;
      padding: 16px;
      width: 340px;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 4px;
      opacity: 0; visibility: hidden;
      transform: translateX(-50%) translateY(-8px);
      transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
      z-index: 200;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(246,188,104,0.08);
    }
    .eco-panel::before {
      content: '';
      position: absolute; top: -6px; left: 50%;
      transform: translateX(-50%) rotate(45deg);
      width: 12px; height: 12px;
      background: rgba(9,19,38,0.97);
      border-left: 1px solid rgba(246,188,104,0.15);
      border-top: 1px solid rgba(246,188,104,0.15);
    }
    .eco-dropdown:hover .eco-panel {
      opacity: 1; visibility: visible;
      transform: translateX(-50%) translateY(0);
    }
    .eco-link {
      display: flex; align-items: center; gap: 8px;
      padding: 10px 12px; border-radius: 10px;
      color: rgba(212,196,178,0.75);
      font-size: 12px; font-family: 'Inter', sans-serif; font-weight: 500;
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
      white-space: nowrap;
    }
    .eco-link:hover {
      background: rgba(246,188,104,0.08);
      color: #f6bc68;
    }
    .eco-link .material-symbols-outlined { font-size: 16px; color: #f6bc68; flex-shrink: 0; }
    html.light .eco-panel { background: rgba(255,252,248,0.98); border-color: rgba(128,86,4,0.15); }
    html.light .eco-panel::before { background: rgba(255,252,248,0.98); border-color: rgba(128,86,4,0.15); }
    html.light .eco-link { color: rgba(60,40,10,0.7); }
    html.light .eco-link:hover { background: rgba(128,86,4,0.06); color: #805604; }
    html.light .eco-link .material-symbols-outlined { color: #805604; }

    .accordion-item {
      border-left: 3px solid #f6bc68;
      transition: border-color 0.3s;
    }
    .accordion-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease-out;
    }
    .accordion-content.active { max-height: 500px; }

    .hero-bg {
      background:
        radial-gradient(ellipse 80% 60% at 70% 30%, rgba(246,188,104,0.06) 0%, transparent 60%),
        radial-gradient(ellipse 60% 50% at 20% 70%, rgba(187,198,230,0.04) 0%, transparent 50%),
        linear-gradient(180deg, #0a1a35 0%, #06132a 100%);
    }

    .bento-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem; }
    @media (min-width: 768px) {
      .bento-grid { grid-template-columns: repeat(16, 1fr); }
      .bento-span-8 { grid-column: span 8; }
      .bento-span-4 { grid-column: span 4; }
    }

    .course-card {
      background: #131f37;
      border: 1px solid #29344e;
      border-radius: 0.5rem;
      padding: 1.5rem;
      transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
      will-change: transform;
    }
    .course-card:hover {
      border-color: #f6bc68;
      transform: translateY(-4px);
      box-shadow: 0 10px 30px rgba(246, 188, 104, 0.15);
    }

    .payment-panel {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease-out;
    }
    .payment-panel.active { max-height: 1200px; }

    .pay-panel {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.45s cubic-bezier(0.22,1,0.36,1), opacity 0.3s ease;
      opacity: 0;
    }
    .pay-panel.open { max-height: 1800px; opacity: 1; }
    .pay-amount-row { display: none; }
    .pay-amount-row.visible { display: flex; }
    .pay-proceed { display: none; }
    .pay-proceed.visible { display: flex; justify-content: center; align-items: center; }
    #payBtn.open .arrow { transform: rotate(180deg); }

    .step { display: none; }
    .step.active { display: block; animation: fadeIn 0.3s; }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    .admin-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.9);
      display: none;
      z-index: 9999;
      align-items: center;
      justify-content: center;
    }
    .admin-overlay.active { display: flex; }

    .admin-panel {
      background: #131f37;
      border: 2px solid #f6bc68;
      border-radius: 1rem;
      padding: 2rem;
      max-width: 90vw;
      max-height: 90vh;
      overflow-y: auto;
      color: #d8e2ff;
    }

    .price-table {
      width: 100%;
      border-collapse: collapse;
      background: #131f37;
      border: 1px solid #29344e;
    }
    .price-table thead {
      background: #1e2a42;
    }
    .price-table th, .price-table td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid #29344e;
    }
    .price-table th {
      color: #f6bc68;
      font-weight: 600;
      font-family: "Inter", sans-serif;
    }
    .price-table tbody tr:hover {
      background: #0f1b33;
    }

    /* Testimonial luxury cards */
    .testimonial-card {
      background: linear-gradient(145deg, #131f37 0%, #0f1928 100%);
      border: 1px solid #29344e;
      border-radius: 1rem;
      padding: 1.5rem;
      transition: border-color 0.4s cubic-bezier(0.22, 1, 0.36, 1), transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s cubic-bezier(0.22, 1, 0.36, 1);
      position: relative;
      overflow: hidden;
      will-change: transform;
    }
    .testimonial-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #f6bc68, #0A66C2, #f6bc68);
      opacity: 0;
      transition: opacity 0.4s;
    }
    .testimonial-card:hover {
      border-color: rgba(246, 188, 104, 0.4);
      transform: translateY(-4px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3), 0 0 30px rgba(246, 188, 104, 0.06);
    }
    .testimonial-card:hover::before {
      opacity: 1;
    }

    .contact-card {
      background: #131f37;
      border: 1px solid #29344e;
      padding: 2rem;
      border-radius: 0.5rem;
      text-align: center;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .contact-card:hover {
      border-color: #f6bc68;
      box-shadow: 0 10px 30px rgba(246, 188, 104, 0.15);
    }

    .admin-trigger {
      position: fixed;
      bottom: 2rem;
      left: 2rem;
      z-index: 1000;
      cursor: pointer;
    }

    @keyframes promoSlideDown {
      0%   { opacity:0; transform: translateY(-100%); }
      100% { opacity:1; transform: translateY(0); }
    }
    @media (max-width: 640px) {
      #stickyPromo { left: 50%; transform: translateX(-50%); bottom: 80px; }
      #stickyPromo > div { width: 240px; }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes leadPopIn {
      from { opacity: 0; transform: scale(0.9) translateY(30px); }
      to { opacity: 1; transform: scale(1) translateY(0); }
    }

    /* ===== PREMIUM THEME TOGGLE ===== */
    .theme-toggle-pill {
      position: relative;
      width: 56px;
      height: 28px;
      border-radius: 99px;
      border: 1px solid rgba(186,135,56,0.35);
      background: linear-gradient(135deg, rgba(13,26,48,0.9) 0%, rgba(9,19,38,0.95) 100%);
      cursor: pointer;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 0 8px rgba(246,188,104,0.08), inset 0 1px 1px rgba(255,255,255,0.04);
      transition: background 0.4s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.4s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      overflow: hidden;
    }
    .theme-toggle-pill:hover {
      border-color: rgba(186,135,56,0.55);
      box-shadow: 0 0 14px rgba(246,188,104,0.15), inset 0 1px 1px rgba(255,255,255,0.06);
    }
    .theme-toggle-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      z-index: 1;
      transition: opacity 0.35s ease, transform 0.35s ease;
    }
    .theme-toggle-icon .material-symbols-outlined {
      font-size: 15px;
    }
    .theme-icon-dark .material-symbols-outlined {
      color: #f6bc68;
    }
    .theme-icon-light .material-symbols-outlined {
      color: #8b9cc5;
    }
    .theme-toggle-knob {
      position: absolute;
      top: 2px;
      left: 2px;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: linear-gradient(135deg, #f6bc68 0%, #e0a030 100%);
      box-shadow: 0 1px 6px rgba(246,188,104,0.35), 0 0 10px rgba(246,188,104,0.12);
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), background 0.4s ease, box-shadow 0.4s ease;
    }
    /* Light mode: knob slides right */
    html.light .theme-toggle-pill {
      background: linear-gradient(135deg, #f2f0eb 0%, #e8e4dc 100%);
      border-color: rgba(128,86,4,0.25);
      box-shadow: 0 0 8px rgba(128,86,4,0.06), inset 0 1px 1px rgba(255,255,255,0.5);
    }
    html.light .theme-toggle-pill:hover {
      border-color: rgba(128,86,4,0.45);
      box-shadow: 0 0 14px rgba(128,86,4,0.1), inset 0 1px 1px rgba(255,255,255,0.5);
    }
    html.light .theme-toggle-knob {
      transform: translateX(28px);
      background: linear-gradient(135deg, #805604 0%, #a67206 100%);
      box-shadow: 0 1px 6px rgba(128,86,4,0.3), 0 0 10px rgba(128,86,4,0.1);
    }
    html.light .theme-icon-dark .material-symbols-outlined {
      color: #a67206;
    }
    html.light .theme-icon-light .material-symbols-outlined {
      color: #504538;
    }

    /* ===== LIGHT MODE HARDCODED OVERRIDES ===== */
    html.light .glass-nav { background: rgba(248,246,242,0.95); }
    html.light .hamburger span { background: #805604; }
    html.light .nav-link::after { background: #805604; }
    html.light .nav-link.active { color: #805604; }

    html.light .hero-bg {
      background:
        radial-gradient(ellipse 80% 60% at 70% 30%, rgba(128,86,4,0.05) 0%, transparent 60%),
        radial-gradient(ellipse 60% 50% at 20% 70%, rgba(59,70,97,0.04) 0%, transparent 50%),
        linear-gradient(180deg, #f8f6f2 0%, #f2f0eb 100%);
    }

    html.light .course-card { background: #ffffff; border-color: #e8e4dc; }
    html.light .course-card:hover { border-color: #805604; box-shadow: 0 10px 30px rgba(128,86,4,0.1); }

    html.light .testimonial-card { background: linear-gradient(145deg, #ffffff 0%, #f8f6f2 100%); border-color: #e8e4dc; }
    html.light .testimonial-card:hover { border-color: rgba(128,86,4,0.4); box-shadow: 0 20px 40px rgba(0,0,0,0.08), 0 0 30px rgba(128,86,4,0.06); }

    html.light .contact-card { background: #ffffff; border-color: #e8e4dc; }
    html.light .contact-card:hover { border-color: #805604; box-shadow: 0 10px 30px rgba(128,86,4,0.1); }

    html.light .admin-panel { background: #ffffff; border-color: #805604; color: #1c1b18; }
    html.light .admin-overlay { background: rgba(0,0,0,0.5); }

    html.light .price-table { background: #ffffff; border-color: #e8e4dc; }
    html.light .price-table thead { background: #f2f0eb; }
    html.light .price-table th { color: #805604; }
    html.light .price-table th, html.light .price-table td { border-color: #e8e4dc; }
    html.light .price-table tbody tr:hover { background: #f8f6f2; }

    html.light .editorial-gradient { background: linear-gradient(135deg, #805604 0%, #a67206 100%); }
    html.light .text-gradient { background: linear-gradient(135deg, #805604 0%, #a67206 100%); -webkit-background-clip: text; background-clip: text; }
  </style>
</head>

<body class="bg-surface text-on-surface smooth-scroll" itemscope itemtype="https://schema.org/WebPage">

  <!-- NAVIGATION -->
  <nav class="glass-nav sticky top-0 z-50 border-b border-surface-container-high">
    <div class="w-full px-6 lg:px-10">
      <div class="flex justify-between items-center h-16">
        <a href="/" class="font-headline font-bold text-2xl text-primary shrink-0">FullOnBaan Education</a>
        <div class="hidden md:flex items-center gap-8">
          <a href="/" class="nav-link text-on-surface hover:text-primary{% if pageId == 'home' %} active{% endif %}">Home</a>
          <a href="/catalog/" class="nav-link text-on-surface hover:text-primary{% if pageId == 'catalog' %} active{% endif %}">Catalog</a>
          <a href="/pricing/" class="nav-link text-on-surface hover:text-primary{% if pageId == 'pricing' %} active{% endif %}">Pricing</a>
          <a href="/testimonials/" class="nav-link text-on-surface hover:text-primary{% if pageId == 'testimonials' %} active{% endif %}">Testimonials</a>
          <a href="/videos/" class="nav-link text-on-surface hover:text-primary{% if pageId == 'videos' %} active{% endif %}">Videos</a>
          <a href="/contact/" class="nav-link text-on-surface hover:text-primary{% if pageId == 'contact' %} active{% endif %}">Contact</a>
          <!-- Ecosystem Dropdown -->
          <div class="eco-dropdown text-on-surface text-sm font-medium">
            <button class="eco-dropdown-btn text-on-surface hover:text-primary text-sm font-medium">
              Ecosystem <span class="material-symbols-outlined eco-arrow">expand_more</span>
            </button>
            <div class="eco-panel">
              <a href="https://home.fullonbaan.com" target="_blank" rel="noopener noreferrer" class="eco-link"><span class="material-symbols-outlined">hub</span>Ecosystem</a>
