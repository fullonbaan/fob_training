  <meta name="twitter:title" content="{{ title }} | FullOnBaan">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="{{ site.url }}/og-image.png">
  <meta name="twitter:image:alt" content="FullOnBaan Infor LN Training Materials">
