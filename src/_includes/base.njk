        '<div style="color:rgba(212,196,178,0.7);margin-top:4px;">Base '+rSym+Number(rec.baseAmt||0).toFixed(2)+' · Tax '+rSym+Number(rec.gstAmt||0).toFixed(2)+' · Total <strong style="color:#f6bc68;">'+rSym+Number(rec.totalAmt||rec.amount||0).toFixed(2)+'</strong> ('+rCurr+')</div>';
