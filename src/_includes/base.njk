      doc.text('training.fullonbaan.com   •   fullonbaan@gmail.com   •   +91 63605 93122',W/2,H-16,{align:'center'});
      return doc;
    }

    /* ── Admin: download GST Invoice for a record ──────────────────────── */
    function admDlInvoice(orderId){
      var rec=admRecs.find(function(x){return x.orderId===orderId;});
      if(!rec){alert('Record not found.');return;}
      try{
        // Compute GST breakdown if not stored (all our transactions are 18% IGST)
        var totalAmt=Number(rec.totalAmt||rec.amount)||0;
        var baseAmt=rec.baseAmt?Number(rec.baseAmt):Math.round(totalAmt/1.18*100)/100;
        var gstAmt=rec.gstAmt?Number(rec.gstAmt):Math.round((totalAmt-baseAmt)*100)/100;
        // Format today as DD/MM/YYYY for invDate fallback
        var today=new Date();
        var fmtD=function(d){return String(d.getDate()).padStart(2,'0')+'/'+String(d.getMonth()+1).padStart(2,'0')+'/'+d.getFullYear();};
        var inv={
          invNo:   rec.invoiceNo||rec.orderId,
          invDate: rec.invDate||fmtD(today),
          dueDate: rec.dueDate||fmtD(new Date(today.getTime()+15*24*60*60*1000)),
          name:    rec.name||'—',
          email:   rec.email||'—',
          mobile:  rec.mobile||'',
          module:  rec.module||'Training Material',
          baseAmt: baseAmt,
          gstAmt:  gstAmt,
          totalAmt:totalAmt,
          paymentId:rec.paymentId||rec.utr||'—',
          orderRef: rec.orderId
        };
        var doc=generateGSTInvoice(inv);doc.save('Invoice-'+inv.invNo+'.pdf');
      }catch(e){console.error('Invoice generation failed',e);alert('Could not generate invoice. Please contact fullonbaan@gmail.com.');}
    }

    function admOpen(){document.getElementById('adminOverlay').classList.add('active');document.getElementById('admLoginDiv').style.display='block';document.getElementById('admDashDiv').style.display='none';document.body.style.overflow='hidden';setTimeout(function(){document.getElementById('admPassword').focus();},50);}
    function admClose(){document.getElementById('adminOverlay').classList.remove('active');document.body.style.overflow='';}
    document.addEventListener('keydown',function(e){if(e.key==='Escape')admClose();});
    (function(){if(window.location.hash==='#admin'){history.replaceState(null,'',window.location.pathname);admOpen();}})();
    window.addEventListener('hashchange',function(){if(window.location.hash==='#admin'){history.replaceState(null,'',window.location.pathname);admOpen();}});

    function admLogin(){var pw=document.getElementById('admPassword').value;if(pw===ADM_PW){document.getElementById('admPassword').value='';document.getElementById('admLoginDiv').style.display='none';document.getElementById('admDashDiv').style.display='block';admRefresh();}else{alert('Invalid password.');}}

    function repairModule(raw,amount){if(!raw)return raw;var validNames=[];for(var k in GUIDES)validNames.push(GUIDES[k].name);if(validNames.indexOf(raw)>=0)return raw;var cleaned=raw.replace(/[^\x20-\x7E]/g,' ').replace(/\s+/g,' ').trim();var best=null;for(var key in GUIDES){var g=GUIDES[key];var words=g.name.replace(/[^\w\s]/g,'').split(/\s+/).filter(function(w){return w.length>2;});var allMatch=words.every(function(w){return cleaned.indexOf(w)>=0;});if(allMatch&&amount&&g.price===Number(amount)){return g.name;}if(allMatch&&!best){best=g.name;}}return best||raw;}
    function repairRecords(recs){return recs.map(function(rec){if(rec.module){rec.module=repairModule(rec.module,rec.amount);}return rec;});}
    async function admGhRead(){var r=await fetch(ADM_API);if(!r.ok)throw new Error('API '+r.status);var d=await r.json();return{records:repairRecords(d.records||[]),sha:d.sha};}
    async function admGhUpsert(rec){try{var gh=await admGhRead();var i=gh.records.findIndex(function(x){return x.orderId===rec.orderId;});if(i>=0)gh.records[i]=Object.assign({},gh.records[i],rec);else gh.records.push(rec);var w=await fetch(ADM_API,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({records:gh.records,sha:gh.sha,message:'lnpay:'+rec.status+' '+rec.orderId})});if(!w.ok)throw new Error('API write '+w.status);}catch(e){console.warn('GitHub sync error:',e);}}
    async function admGhMerge(){var r=await admGhRead();return r.records;}
    window.lnPayInitiated=function(txnRefVal,userDataVal,selDescVal,selAmountVal){var rec={orderId:txnRefVal,status:'initiated',name:userDataVal.name,email:userDataVal.email,mobile:userDataVal.mobile,module:selDescVal,amount:selAmountVal,initiatedAt:new Date().toISOString(),submittedAt:null,utr:null};admGhUpsert(rec);};
    window.lnPaySubmitted=function(txnRefVal,utrVal){var upd={orderId:txnRefVal,status:'submitted',utr:utrVal,submittedAt:new Date().toISOString()};admGhUpsert(upd);};
    async function admRefresh(){document.getElementById('admRenderDiv').innerHTML='<p class="text-on-surface-variant text-sm">Loading from GitHub...</p>';try{admRecs=await admGhMerge();}catch(e){document.getElementById('admRenderDiv').innerHTML='<p class="text-error text-sm">Failed to fetch from GitHub.</p>';return;}admRender();}
    function admRender(){
      // Sort descending: confirmed > submitted > initiated date
      var r=admRecs.slice().sort(function(a,b){
        var da=new Date(a.confirmedAt||a.submittedAt||a.initiatedAt||0);
        var db=new Date(b.confirmedAt||b.submittedAt||b.initiatedAt||0);
        return db-da;
      });
      var div=document.getElementById('admRenderDiv');
      if(!r.length){div.innerHTML='<p class="text-on-surface-variant text-sm">No records found.</p>';return;}
      function fmtDate(d){if(!d)return '\u2014';var dt=new Date(d);return dt.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'})+' '+dt.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',hour12:true});}
      function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
      function escQ(s){return String(s||'').replace(/\\/g,'\\\\').replace(/'/g,"\\'");}
      div.innerHTML=r.map(function(rec){
        var confirmed=rec.status==='confirmed';
        var submitted=rec.status==='submitted';
        var statusCls=confirmed?'bg-green-400/10 text-green-400 border border-green-400/25':submitted?'bg-yellow-400/10 text-yellow-400 border border-yellow-400/25':'bg-blue-400/10 text-blue-400 border border-blue-400/25';
        var statusTxt=confirmed?'Confirmed':submitted?'Submitted':'Initiated';
        var amtDisplay=rec.totalAmt?('\u20B9'+Number(rec.totalAmt).toLocaleString('en-IN',{minimumFractionDigits:2,maximumFractionDigits:2})):rec.amount?('\u20B9'+Number(rec.amount).toLocaleString('en-IN')):'\u2014';
        var gstRow=rec.baseAmt&&rec.gstAmt?'<span class="text-on-surface-variant/60 font-label text-xs">GST Breakdown</span><span class="text-on-surface-variant text-xs">Base \u20B9'+Number(rec.baseAmt).toFixed(2)+' + IGST \u20B9'+Number(rec.gstAmt).toFixed(2)+'</span>':'';
        var invRow=rec.invoiceNo?'<span class="text-on-surface-variant/60 font-label text-xs">Invoice No</span><span class="text-on-surface-variant text-xs font-mono">'+esc(rec.invoiceNo)+'</span>':'';
        var payIdRow=rec.paymentId?'<span class="text-on-surface-variant/60 font-label text-xs">Payment ID</span><span class="text-on-surface-variant text-xs font-mono">'+esc(rec.paymentId)+'</span>':'';
        var confirmedRow=rec.confirmedAt?'<span class="text-on-surface-variant/60 font-label text-xs">Confirmed</span><span class="text-on-surface-variant text-xs">'+fmtDate(rec.confirmedAt)+'</span>':'';
        var submittedRow=rec.submittedAt?'<span class="text-on-surface-variant/60 font-label text-xs">Submitted</span><span class="text-on-surface-variant text-xs">'+fmtDate(rec.submittedAt)+'</span>':'';
        // GST Invoice button — shown for all confirmed records (all transactions include 18% IGST)
        var invBtn=confirmed?'<button onclick="admDlInvoice(\''+escQ(rec.orderId)+'\')" style="margin-top:6px;display:inline-flex;align-items:center;gap:5px;background:linear-gradient(135deg,#f6bc68,#ba8738);color:#06132a;padding:4px 10px;border-radius:6px;font-size:11px;font-weight:700;border:none;cursor:pointer;white-space:nowrap;" onmouseover="this.style.opacity=\'0.85\'" onmouseout="this.style.opacity=\'1\'">&#x1F4C4; GST Invoice</button>':'';
        return '<div class="bg-surface-container-low p-5 rounded-lg mb-3 border border-outline-variant/20">'
          // Header: name on left, status badge + invoice button stacked on right
          +'<div class="flex justify-between items-start mb-4">'
          +'<strong class="text-on-surface text-base">'+esc(rec.name||'\u2014')+'</strong>'
          +'<div style="display:flex;flex-direction:column;align-items:flex-end;gap:0;">'
          +'<span class="text-[10px] font-bold px-2.5 py-1 rounded-full '+statusCls+'">'+statusTxt+'</span>'
          +invBtn
          +'</div>'
          +'</div>'
          // Details grid
          +'<div class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-2 text-sm">'
          +'<span class="text-on-surface-variant/60 font-label text-xs">Email</span><span class="text-on-surface-variant">'+esc(rec.email||'\u2014')+'</span>'
          +'<span class="text-on-surface-variant/60 font-label text-xs">Mobile</span><span class="text-on-surface-variant">'+(rec.mobile?'+91 '+esc(rec.mobile):'\u2014')+'</span>'
          +'<span class="text-on-surface-variant/60 font-label text-xs">Module</span><span class="text-primary font-semibold">'+esc(rec.module||'\u2014')+'</span>'
          +'<span class="text-on-surface-variant/60 font-label text-xs">Amount</span><span class="text-primary font-semibold">'+amtDisplay+'</span>'
          +gstRow
          +'<span class="text-on-surface-variant/60 font-label text-xs">Order ID</span><span class="text-on-surface-variant text-xs font-mono">'+esc(rec.orderId||'\u2014')+'</span>'
          +(rec.utr?'<span class="text-on-surface-variant/60 font-label text-xs">UTR</span><span class="text-on-surface-variant text-xs font-mono">'+esc(rec.utr)+'</span>':'')
          +payIdRow+invRow
          +'<span class="text-on-surface-variant/60 font-label text-xs">Initiated</span><span class="text-on-surface-variant text-xs">'+fmtDate(rec.initiatedAt)+'</span>'
          +submittedRow+confirmedRow
          +'</div>'
          +'</div>';
      }).join('');
    }

