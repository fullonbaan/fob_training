    function admEdGstinToggle(){var on=document.getElementById('admEd_gstinToggle').checked;document.getElementById('admEd-gstin-fields').style.display=on?'grid':'none';}
    function admEdRefreshPreview(){
      if(!admEdRec)return;
      var prev=document.getElementById('admEd-preview');
      var rCurr=admEdRec.currency||'INR';
      var rSym={INR:'₹',USD:'$',EUR:'€',GBP:'£'}[rCurr]||(rCurr+' ');
      var base=Number(admEdRec.baseAmt||0);
      if(rCurr!=='INR'){prev.innerHTML='<strong style="color:#fbbf24;">No GST</strong> — international currency ('+rCurr+'). Base '+rSym+base.toFixed(2)+' = Total '+rSym+base.toFixed(2)+'.';return;}
      var country=document.getElementById('admEd_billCountry').value;
      var stCd=(country==='IN')?document.getElementById('admEd_billState').value:'';
      if(country!=='IN'){prev.innerHTML='<strong style="color:#fbbf24;">Buyer outside India</strong> — invoice will be issued without GST.';return;}
      if(!stCd){prev.innerHTML='<strong style="color:#fbbf24;">Pick a state</strong> to see whether CGST+SGST or IGST applies.';return;}
      var split=calcGSTSplit(base,stCd);
      if(split.taxType==='CGST_SGST'){
        prev.innerHTML='<strong style="color:#4ade80;">CGST 9% + SGST 9%</strong> (intra-state, '+getStateNameByCode(stCd)+'): Base '+rSym+split.base.toFixed(2)+' &nbsp;·&nbsp; CGST '+rSym+split.cgst.toFixed(2)+' + SGST '+rSym+split.sgst.toFixed(2)+' &nbsp;·&nbsp; <strong>Total '+rSym+split.total.toFixed(2)+'</strong>';
      } else {
        prev.innerHTML='<strong style="color:#4ade80;">IGST @ 18%</strong> (inter-state, '+getStateNameByCode(stCd)+'): Base '+rSym+split.base.toFixed(2)+' &nbsp;·&nbsp; IGST '+rSym+split.igst.toFixed(2)+' &nbsp;·&nbsp; <strong>Total '+rSym+split.total.toFixed(2)+'</strong>';
      }
    }
    async function admEditSave(){
      if(!admEdRec)return;
      var err=document.getElementById('admEd-err'); err.textContent='';
      var company=(document.getElementById('admEd_billCompany').value||'').trim();
      var line1  =(document.getElementById('admEd_billLine1').value||'').trim();
      var line2  =(document.getElementById('admEd_billLine2').value||'').trim();
      var city   =(document.getElementById('admEd_billCity').value||'').trim();
      var pin    =(document.getElementById('admEd_billPin').value||'').trim();
      var country=(document.getElementById('admEd_billCountry').value||'IN').trim();
      var stCd='', stName='';
      if(country==='IN'){
        stCd=document.getElementById('admEd_billState').value||'';
        stName=stCd?getStateNameByCode(stCd):'';
      } else {
        stName=(document.getElementById('admEd_billStateText').value||'').trim();
      }
      var gstinOn=!!document.getElementById('admEd_gstinToggle').checked;
      var gstin=gstinOn?(document.getElementById('admEd_gstin').value||'').toUpperCase().trim():'';
      var legalName=gstinOn?(document.getElementById('admEd_gstLegalName').value||'').trim():'';

      if(!line1){err.textContent='Address Line 1 is required.';return;}
      if(!city){err.textContent='City is required.';return;}
      if(!pin){err.textContent='PIN / ZIP is required.';return;}
      if(country==='IN' && !stCd){err.textContent='Please select an Indian state — it determines CGST+SGST vs IGST.';return;}
      if(country!=='IN' && !stName){err.textContent='Please enter the state / region.';return;}
      if(country==='IN' && !/^\d{6}$/.test(pin)){err.textContent='Indian PIN code must be 6 digits.';return;}
      if(gstinOn){
        if(!isValidGSTIN(gstin)){err.textContent='GSTIN format is invalid (expected 15 chars).';return;}
        if(country==='IN' && gstinStateCode(gstin)!==stCd){err.textContent='GSTIN starts with state code '+gstinStateCode(gstin)+' but state is '+stName+' ('+stCd+'). They must match.';return;}
        if(!legalName){err.textContent='Legal name of business is required when GSTIN is provided.';return;}
      }

      var rCurr=admEdRec.currency||'INR';
      var base=Number(admEdRec.baseAmt||0);
      var cgst=0, sgst=0, igst=0, gstAmt=Number(admEdRec.gstAmt||0), total=Number(admEdRec.totalAmt||admEdRec.amount||0), taxType=admEdRec.taxType||'NONE';
      if(rCurr==='INR' && base>0){
        var split=calcGSTSplit(base, country==='IN'?stCd:'');
        cgst=split.cgst; sgst=split.sgst; igst=split.igst;
        gstAmt=split.gst; total=split.total; taxType=split.taxType;
      }
      var merged=Object.assign({},admEdRec,{
        billCompany:company,billLine1:line1,billLine2:line2,billCity:city,billPincode:pin,
        billCountry:country,billStateCode:stCd,billStateName:stName,
        gstin:gstin,gstLegalName:legalName,
        placeOfSupply:stName?(stName+(stCd?' ('+stCd+')':'')):'',
        cgstAmt:cgst,sgstAmt:sgst,igstAmt:igst,gstAmt:gstAmt,totalAmt:total,taxType:taxType,
        billingUpdatedAt:new Date().toISOString()
      });

      var btn=document.getElementById('admEd-saveBtn');
      var orig=btn.textContent;
      btn.disabled=true; btn.textContent='⏳ Saving…';
      try {
        await admGhUpsert(merged);
        var i=admRecs.findIndex(function(x){return x.orderId===merged.orderId;});
        if(i>=0) admRecs[i]=merged;
        admRender();
        admEditClose();
      } catch(e){console.error(e);err.textContent='Save failed: '+(e.message||'unknown error');}
      finally { btn.disabled=false; btn.textContent=orig; }
    }
