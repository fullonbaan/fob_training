    var GST_RATE_FULL=0.18;
    function calcGSTSplit(basePrice,buyerStateCode){
      var base=Math.round(basePrice*100)/100;
      var totalGst=Math.round(base*GST_RATE_FULL*100)/100;
      var total=Math.round((base+totalGst)*100)/100;
      var isIntra=!!buyerStateCode && String(buyerStateCode)===SELLER_STATE_CODE;
      if(isIntra){
        var cgst=Math.round(base*0.09*100)/100;
        var sgst=Math.round((totalGst-cgst)*100)/100;
        return{base:base,cgst:cgst,sgst:sgst,igst:0,gst:totalGst,total:total,taxType:'CGST_SGST'};
      }
      return{base:base,cgst:0,sgst:0,igst:totalGst,gst:totalGst,total:total,taxType:'IGST'};
    }
