    // Exit-intent detection: trigger when mouse leaves viewport toward top
    document.addEventListener('mouseout', function(e) {
      if (e.clientY < 5 && !e.relatedTarget && !e.toElement) {
        showLeadPopup();
      }
    });
    // Mobile fallback: show after 30 seconds of scroll activity
    var leadScrollTimer = null;
    window.addEventListener('scroll', function() {
      if (leadPopupShown) return;
      if (leadScrollTimer) clearTimeout(leadScrollTimer);
      leadScrollTimer = setTimeout(function() {
        var scrollPct = window.scrollY / (document.body.scrollHeight - window.innerHeight);
        if (scrollPct > 0.5) showLeadPopup();
      }, 30000);
    }, { passive: true });
    // Close on Escape
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeLeadPopup(); });

    // ===== THEME TOGGLE =====
    function toggleTheme() {
      var html = document.documentElement;
      var isLight = html.classList.contains('light');
      if (isLight) {
        html.classList.remove('light');
        html.classList.add('dark');
        try { localStorage.setItem('fob_theme', 'dark'); } catch(e) {}
      } else {
        html.classList.remove('dark');
        html.classList.add('light');
        try { localStorage.setItem('fob_theme', 'light'); } catch(e) {}
      }
      updateThemeIcons();
    }
    function updateThemeIcons() {
      // Pill toggle handles state via CSS (html.light class moves the knob)
      // No icon visibility toggling needed — both icons always show
    }
    // Init icons on load
    updateThemeIcons();

    // Accordion (shared)
    function toggleAccordion(button) {
      const content = button.nextElementSibling;
      const isActive = content.classList.contains('active');
      document.querySelectorAll('.accordion-content').forEach(c => c.classList.remove('active'));
      document.querySelectorAll('.accordion-item button span:last-child').forEach(s => s.textContent = '+');
      if (!isActive) {
        content.classList.add('active');
        button.querySelector('span:last-child').textContent = '−';
      }
    }
  </script>

