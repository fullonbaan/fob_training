    // Currency conversion
    var CURRENCY_RATES = { INR:{symbol:'₹',rate:1}, USD:{symbol:'$',rate:85}, EUR:{symbol:'€',rate:92} };
    var GUIDES_INR = {}; // store original INR prices
    Object.keys(GUIDES).forEach(function(k){ GUIDES_INR[k] = GUIDES[k].price; });

    var FIXED_PRICES = { 499:{USD:10,EUR:9}, 999:{USD:20,EUR:20}, 1999:{USD:30,EUR:28}, 2499:{USD:40,EUR:37}, 3488:{USD:45,EUR:40}, 3999:{USD:59,EUR:55}, 4499:{USD:65,EUR:60}, 4488:{USD:39,EUR:36}, 6999:{USD:99,EUR:95}, 7999:{USD:109,EUR:99}, 11487:{USD:159,EUR:149}, 12793:{USD:165,EUR:149}, 12994:{USD:160,EUR:149}, 14999:{USD:199,EUR:189}, 18999:{USD:245,EUR:225}, 19199:{USD:249,EUR:229}, 27993:{USD:359,EUR:339}, 31992:{USD:419,EUR:389} };

    function convertPrice(inrAmount, currency) {
      if (currency === 'INR') return inrAmount;
      if (FIXED_PRICES[inrAmount] && FIXED_PRICES[inrAmount][currency]) return FIXED_PRICES[inrAmount][currency];
      var c = CURRENCY_RATES[currency];
      var converted = (inrAmount / c.rate) * 1.25;
      return Math.ceil(converted / 5) * 5; // round up to nearest 5
    }

    function formatPrice(amount, currency) {
      var s = CURRENCY_RATES[currency].symbol;
      if (currency === 'INR') return s + amount.toLocaleString('en-IN');
      return s + amount.toLocaleString('en-US');
    }

    function switchCurrency(currency) {
      // Sync both dropdowns
      var d = document.getElementById('currencySelect');
      var m = document.getElementById('currencySelectMobile');
      if (d) d.value = currency;
      if (m) m.value = currency;

      // Update GUIDES prices for payment flow
      Object.keys(GUIDES).forEach(function(k){
        GUIDES[k].price = convertPrice(GUIDES_INR[k], currency);
      });

      // Update all price elements with data-inr
      document.querySelectorAll('[data-inr]').forEach(function(el){
        var inr = parseInt(el.getAttribute('data-inr'));
        var converted = convertPrice(inr, currency);
        el.textContent = formatPrice(converted, currency);
      });

      // Update Compare Plans footer note
      var cpNote = document.getElementById('comparePricingNote');
      if (cpNote) {
        var sym = CURRENCY_RATES[currency].symbol;
        cpNote.innerHTML = 'All prices in ' + currency + ' (' + sym + ') &nbsp;&middot;&nbsp; No hidden fees &nbsp;&middot;&nbsp; Instant digital delivery';
      }

      // Update pricing dropdown options
      var modSelect = document.getElementById('modSelect');
      if (modSelect) {
        modSelect.querySelectorAll('option[value]').forEach(function(opt){
          if (!opt.value) return;
          var g = GUIDES[opt.value];
          if (g) {
            var label = g.name + ' (' + formatPrice(g.price, currency) + ')';
            opt.textContent = label;
          }
        });
      }

      // Update payment amount display if visible
      if (typeof onModuleChange === 'function') {
        var ms = document.getElementById('modSelect');
        if (ms && ms.value) onModuleChange();
      }

      // Store preference
      try { localStorage.setItem('fob_currency', currency); } catch(e){}
    }

    // Restore saved currency preference
    try {
      var savedCurrency = localStorage.getItem('fob_currency');
      if (savedCurrency && CURRENCY_RATES[savedCurrency]) {
        document.addEventListener('DOMContentLoaded', function(){ switchCurrency(savedCurrency); });
      }
    } catch(e){}

    var ADM_PW='Admin@M3Pay2025';
    var ADM_API='/api/payments';
    var admRecs=[],admFl='all';
    // Logo placeholder — pricing.njk overrides with actual base64 when loaded on that page
    var FOB_LOGO_B64='data:image/jpeg;base64,';

    /* ── Number-to-Words (Indian or international) ────────────────────── */
    function numToWords(n,currency){
      var ones=['','One','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten','Eleven','Twelve','Thirteen','Fourteen','Fifteen','Sixteen','Seventeen','Eighteen','Nineteen'];
      var tens=['','','Twenty','Thirty','Forty','Fifty','Sixty','Seventy','Eighty','Ninety'];
      var curr=currency||'INR';
      function convIN(x){if(x===0)return'';if(x<20)return ones[x]+' ';if(x<100)return tens[Math.floor(x/10)]+' '+(x%10?ones[x%10]+' ':'');if(x<1000)return ones[Math.floor(x/100)]+' Hundred '+(x%100?convIN(x%100):'');if(x<100000)return convIN(Math.floor(x/1000))+'Thousand '+(x%1000?convIN(x%1000):'');if(x<10000000)return convIN(Math.floor(x/100000))+'Lakh '+(x%100000?convIN(x%100000):'');return convIN(Math.floor(x/10000000))+'Crore '+(x%10000000?convIN(x%10000000):'');}
      function convEN(x){if(x===0)return'';if(x<20)return ones[x]+' ';if(x<100)return tens[Math.floor(x/10)]+' '+(x%10?ones[x%10]+' ':'');if(x<1000)return ones[Math.floor(x/100)]+' Hundred '+(x%100?convEN(x%100):'');if(x<1000000)return convEN(Math.floor(x/1000))+'Thousand '+(x%1000?convEN(x%1000):'');if(x<1000000000)return convEN(Math.floor(x/1000000))+'Million '+(x%1000000?convEN(x%1000000):'');return convEN(Math.floor(x/1000000000))+'Billion '+(x%1000000000?convEN(x%1000000000):'');}
      var r=Math.floor(n),p=Math.round((n-r)*100);
      var labels={INR:{name:'Indian Rupee',sub:'Paise'},USD:{name:'US Dollar',sub:'Cents'},EUR:{name:'Euro',sub:'Cents'},GBP:{name:'Pound Sterling',sub:'Pence'}};
      var lbl=labels[curr]||{name:curr,sub:'Cents'};
      var conv=(curr==='INR')?convIN:convEN;
      var w=lbl.name+' '+conv(r).trim()+(p?' and '+conv(p).trim()+' '+lbl.sub:'')+' Only';
      return w.replace(/\s+/g,' ');
