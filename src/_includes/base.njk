    /* ── Admin: download GST Invoice for a record ──────────────────────── */
    function admDlInvoice(orderId){
      var rec=admRecs.find(function(x){return x.orderId===orderId;});
      if(!rec){alert('Record not found.');return;}
      try{
        // Compute GST breakdown if not stored. Only legacy INR records had GST baked in.
        var recCurr=rec.currency||'INR';
        var totalAmt=Number(rec.totalAmt||rec.amount)||0;
        var baseAmt,gstAmt;
        if(recCurr==='INR'){
          baseAmt=rec.baseAmt?Number(rec.baseAmt):Math.round(totalAmt/1.18*100)/100;
          gstAmt=rec.gstAmt?Number(rec.gstAmt):Math.round((totalAmt-baseAmt)*100)/100;
        }else{
          baseAmt=rec.baseAmt?Number(rec.baseAmt):totalAmt;
          gstAmt=0;
        }
        // Format today as DD/MM/YYYY for invDate fallback
        var today=new Date();
        var fmtD=function(d){return String(d.getDate()).padStart(2,'0')+'/'+String(d.getMonth()+1).padStart(2,'0')+'/'+d.getFullYear();};
        var inv={
          invNo:   rec.invoiceNo||rec.orderId,
          invDate: rec.invDate||fmtD(today),
          dueDate: rec.dueDate||fmtD(new Date(today.getTime()+15*24*60*60*1000)),
          name:    rec.name||'—',
          email:   rec.email||'—',
          mobile:  rec.mobile||'',
          mobileCode: rec.mobileCode||'+91',
          module:  rec.module||'Training Material',
          currency: recCurr,
          baseAmt: baseAmt,
          gstAmt:  gstAmt,
          totalAmt:totalAmt,
          /* Billing & GST split — newly captured fields, populated for backfilled records */
          cgstAmt: Number(rec.cgstAmt||0), sgstAmt: Number(rec.sgstAmt||0), igstAmt: Number(rec.igstAmt||0),
          taxType: rec.taxType||'',
          billCompany: rec.billCompany||'', billLine1: rec.billLine1||'', billLine2: rec.billLine2||'',
          billCity: rec.billCity||'', billPincode: rec.billPincode||'',
          billStateCode: rec.billStateCode||'', billStateName: rec.billStateName||'',
          billCountry: rec.billCountry||'IN',
          gstin: rec.gstin||'', gstLegalName: rec.gstLegalName||'',
          placeOfSupply: rec.placeOfSupply||'',
          paymentId:rec.paymentId||rec.utr||'—',
          orderRef: rec.orderId
        };
        var doc=generateGSTInvoice(inv);doc.save('Invoice-'+inv.invNo+'.pdf');
      }catch(e){console.error('Invoice generation failed',e);alert('Could not generate invoice. Please contact fullonbaan@gmail.com.');}
    }

