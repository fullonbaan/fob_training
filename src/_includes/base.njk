      });
      // Auto-download the eBook
      var dlLink = document.createElement('a');
      dlLink.href = '/preview/Free_Infor_LN_Starter_Guide_Top_10_Things.pdf';
      dlLink.download = 'Free_Infor_LN_Starter_Guide_Top_10_Things.pdf';
      document.body.appendChild(dlLink);
      dlLink.click();
      document.body.removeChild(dlLink);
      // Show success
      document.getElementById('leadPopupForm').style.display = 'none';
      document.getElementById('leadPopupSuccess').style.display = 'block';
      try { localStorage.setItem('fob_lead_captured', '1'); } catch(e) {}
      setTimeout(closeLeadPopup, 6000);
    }
    // Also share submit for the inline form
    window.submitLeadInline = function() {
      var name = document.getElementById('leadInlineName').value.trim();
