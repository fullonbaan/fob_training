      // Send notification to admin
      sendEmail({
        to_email: 'fullonbaan@gmail.com',
        subject: 'New Lead — Free Starter Guide Download',
        status: 'NEW LEAD',
        order_ref: 'LEAD' + Date.now(),
        utr_number: 'N/A',
        guide: 'Free Infor LN Starter Guide',
        amount: 'FREE',
        cust_name: name,
        cust_email: email,
        cust_mobile: 'N/A',
        message: name + ' (' + email + ') requested the free Infor LN Starter Guide.'
      });
      // Send guide to user
      sendEmail({
        to_email: email,
        subject: 'Your Free Infor LN Starter Guide — FullOnBaan',
        status: 'LEAD MAGNET DELIVERED',
        order_ref: 'LEAD' + Date.now(),
        utr_number: 'N/A',
        guide: 'Free Infor LN Starter Guide',
        amount: 'FREE',
        cust_name: name,
        cust_email: email,
        cust_mobile: 'N/A',
