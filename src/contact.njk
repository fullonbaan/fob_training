{% block scripts %}
<script>
window.sendInquiry=function(){var name=document.getElementById('inqName').value.trim(),email=document.getElementById('inqEmail').value.trim(),phone=document.getElementById('inqPhone').value.trim(),mod=document.getElementById('inqModule').value,callback=document.getElementById('inqCallback').value,msg=document.getElementById('inqMessage').value.trim(),err=document.getElementById('inqError'),ok=document.getElementById('inqSuccess');err.textContent='';ok.style.display='none';if(!name){err.textContent='Please enter your name.';return;}if(!email||!email.includes('@')){err.textContent='Please enter a valid email address.';return;}if(!phone||phone.length<10){err.textContent='Please enter a valid phone number.';return;}if(!mod||mod==='Select a Training *'){err.textContent='Please select a training module.';return;}var fullMsg=(msg||'(no message)')+'\n\nCallback Preference: '+(callback&&callback!=='Preferred Callback Time (Optional)'?callback:'Not specified');sendEmail({to_email:'fullonbaan@gmail.com',subject:'Free Consultation Request — '+mod,status:'NEW CONSULTATION REQUEST',order_ref:'INQ'+Date.now(),utr_number:'N/A',guide:mod,amount:'N/A',cust_name:name,cust_email:email,cust_mobile:phone,message:fullMsg});ok.style.display='block';document.getElementById('inqName').value='';document.getElementById('inqEmail').value='';document.getElementById('inqPhone').value='';document.getElementById('inqModule').selectedIndex=0;document.getElementById('inqCallback').selectedIndex=0;document.getElementById('inqMessage').value='';};
</script>
