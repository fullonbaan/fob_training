    return '₹';
  }
  function formatAmt(amount, curr) {
    var sym = getCurrSymbol(curr);
    if (curr === 'INR') return sym + Number(amount).toLocaleString('en-IN', {minimumFractionDigits:2});
    return sym + Number(amount).toLocaleString('en-US', {minimumFractionDigits:2});
  }
  // For INR: apply 18% GST. For international currencies: no GST (flat price).
  function calcPaymentDetails(basePrice, currency) {
    if (currency === 'INR') {
