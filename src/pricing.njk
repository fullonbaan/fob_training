      cards.forEach(function(c) { c.style.display = ''; });
      bundleSection.style.display = '';
      return;
    }

    // Show/hide cards based on data-category
    cards.forEach(function(c) {
      var cat = c.getAttribute('data-category') || '';
      c.style.display = (cat === category) ? '' : 'none';
    });

    // Bundles only visible on 'all' or 'bundle' filter
    bundleSection.style.display = (category === 'bundle') ? '' : 'none';
