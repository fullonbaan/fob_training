  /* ── GitHub invoice counter ──────────────────────────────────────────── */
  async function genInvoiceNoGH() {
    try {
      var r = await fetch(ADM_GH_INV_API,{headers:{'Authorization':'token '+ADM_GH_PAT,'Accept':'application/vnd.github.v3+json'}});
      var current=1000, sha=null;
      if(r.ok){var d=await r.json();var data=JSON.parse(atob(d.content.replace(/\n/g,'')));current=data.counter||1000;sha=d.sha;}
      var next=current+1;
      var body={message:'training-inv:'+next,content:btoa(JSON.stringify({counter:next},null,2))};
      if(sha)body.sha=sha;
      await fetch(ADM_GH_INV_API,{method:'PUT',headers:{'Authorization':'token '+ADM_GH_PAT,'Accept':'application/vnd.github.v3+json','Content-Type':'application/json'},body:JSON.stringify(body)});
      return 'FOBT'+String(next).padStart(7,'0');
    } catch(e) {
      console.warn('Invoice counter GitHub error — using timestamp fallback:',e);
      return 'FOBT'+String(Date.now()).slice(-7);
