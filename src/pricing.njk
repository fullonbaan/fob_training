    doc.setFont('helvetica','normal');doc.setFontSize(8.5);doc.setTextColor(GREY[0],GREY[1],GREY[2]);doc.text('Amount in Words:',PAD+10,wY+16);
    doc.setFont('helvetica','bolditalic');doc.setFontSize(9);doc.setTextColor(NAVY[0],NAVY[1],NAVY[2]);
    doc.text(doc.splitTextToSize(numToWords(inv.totalAmt),W-2*PAD-130),PAD+120,wY+16);
    var tcY=wY+62;
    doc.setFont('helvetica','bold');doc.setFontSize(9);doc.setTextColor(NAVY[0],NAVY[1],NAVY[2]);doc.text('Terms & Conditions',PAD,tcY+2);
    doc.setDrawColor(GOLD[0],GOLD[1],GOLD[2]);doc.setLineWidth(0.6);doc.line(PAD,tcY+6,W-PAD,tcY+6);
    doc.setFont('helvetica','normal');doc.setFontSize(8.5);doc.setTextColor(GREY[0],GREY[1],GREY[2]);
    doc.text(['* This is a computer-generated tax invoice for a digital product (Training Material).','* SAC Code 998431 — Online content delivery services.','* For queries or disputes, contact fullonbaan@gmail.com within 7 days of purchase.','* WhatsApp: +91 63605 93122   |   training.fullonbaan.com'],PAD,tcY+20,{lineHeightFactor:1.75});
    doc.setFillColor(NAVY[0],NAVY[1],NAVY[2]);doc.rect(0,H-38,W,38,'F');
    doc.setFillColor(GOLD[0],GOLD[1],GOLD[2]);doc.rect(0,H-42,W,4,'F');
    doc.setFont('helvetica','normal');doc.setFontSize(8.5);doc.setTextColor(GOLD2[0],GOLD2[1],GOLD2[2]);
    doc.text('training.fullonbaan.com   •   fullonbaan@gmail.com   •   +91 63605 93122',W/2,H-16,{align:'center'});
    return doc;
  }

  window.downloadInvoice=function(invData){
    var d=invData||currentInvData;
    if(!d){alert('Invoice not available. Please contact support.');return;}
    try{var doc=generateGSTInvoice(d);doc.save('Invoice-'+d.invNo+'.pdf');}
    catch(e){console.error('Invoice generation failed',e);alert('Could not generate invoice. Please contact fullonbaan@gmail.com.');}
  };

  /* ══════════════════════════════════════════════════════════════════════
     ADMIN PANEL
  ══════════════════════════════════════════════════════════════════════ */
  var admRecs=[], admFl='all';

  function admOpen(){
    var ol=document.getElementById('adm-overlay');
    ol.style.display='flex';ol.style.flexDirection='column';
    document.getElementById('adm-login').style.display='flex';
    document.getElementById('adm-dash').style.display='none';
    document.body.style.overflow='hidden';
    setTimeout(function(){document.getElementById('adm-pw').focus();},50);
  }
  function admClose(){document.getElementById('adm-overlay').style.display='none';document.body.style.overflow='';}
  document.addEventListener('keydown',function(e){if(e.key==='Escape')admClose();});

  function admLogin(){
    var pw=document.getElementById('adm-pw').value;
    if(pw===ADM_PW){
      document.getElementById('adm-pw').value='';
      document.getElementById('adm-login').style.display='none';
      document.getElementById('adm-dash').style.display='flex';
      admRefresh();
    }else{
      document.getElementById('adm-err').style.display='block';
    }
  }

  async function admGhMerge(){
    var gh=[];
    try{var r=await ghRead();gh=r.records;admSync('ok','Synced');}
    catch(e){admSync('err','Offline');}
    var lo=JSON.parse(localStorage.getItem('training_payments')||'[]');
    var m=gh.slice();
    lo.forEach(function(l){if(!m.find(function(x){return x.orderId===l.orderId;}))m.push(l);});
    localStorage.setItem('training_payments',JSON.stringify(m));
    return m;
  }

  async function admRefresh(){
    document.getElementById('alist').innerHTML='<div style="text-align:center;color:rgba(212,196,178,0.4);padding:40px;">⏳ Syncing with GitHub…</div>';
    admSync('spin','Syncing…');
    try{admRecs=await admGhMerge();}
    catch(e){admRecs=JSON.parse(localStorage.getItem('training_payments')||'[]');admSync('err','Offline');}
    admStats();admRender();
  }

  function admStats(){
    var i=admRecs.filter(function(r){return r.status==='initiated';}).length;
    var s=admRecs.filter(function(r){return r.status==='confirmed';}).length;
    document.getElementById('ast-all').textContent=admRecs.length;
    document.getElementById('ast-init').textContent=i;
    document.getElementById('ast-sub').textContent=s;
  }

  function admFilt(f,btn){
    admFl=f;
    document.querySelectorAll('.afbtn').forEach(function(b){
      b.style.background='transparent';b.style.color='rgba(212,196,178,0.5)';
    });
    btn.style.background='rgba(246,188,104,0.12)';btn.style.color='#f6bc68';
    admRender();
  }

  function admRender(){
    var q=(document.getElementById('asrch').value||'').toLowerCase();
    var r=admFl==='all'?admRecs:admRecs.filter(function(x){return x.status===admFl;});
    if(q)r=r.filter(function(x){return['name','email','mobile','module','orderId','paymentId'].some(function(k){return(x[k]||'').toLowerCase().includes(q);});});
    r=r.slice().sort(function(a,b){return new Date(b.confirmedAt||b.initiatedAt||0)-new Date(a.confirmedAt||a.initiatedAt||0);});
    var el=document.getElementById('alist');
    if(!r.length){el.innerHTML='<div style="text-align:center;color:rgba(212,196,178,0.4);padding:40px;">No records found.</div>';return;}
    el.innerHTML=r.map(admCard).join('');
  }

  function ft(d){return d?new Date(d).toLocaleString('en-IN',{timeZone:'Asia/Kolkata',day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}):'—';}
  function aH(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
  function aE(s){return String(s||'').replace(/\\/g,'\\\\').replace(/'/g,"\\'");}

  function admCard(r){
    var s=r.status==='confirmed', f=r.status==='failed';
    var badgeColor=s?'#4ade80':f?'#f87171':'#fbbf24';
    var badgeLabel=s?'✅ Confirmed':f?'❌ Failed':'💳 Initiated';
    var gstLine='';
    if(r.baseAmt&&r.gstAmt){gstLine='<div style="margin-top:4px;font-size:11px;color:#4ade80;">Base Rs.'+Number(r.baseAmt).toFixed(2)+' + GST Rs.'+Number(r.gstAmt).toFixed(2)+'</div>';}
    var acts='';
    if(r.email)acts+='<button onclick="admCp(\''+aE(r.email)+'\',\'Email\')" style="padding:5px 10px;background:rgba(246,188,104,0.1);border:1px solid rgba(246,188,104,0.2);color:#f6bc68;border-radius:6px;cursor:pointer;font-size:11px;">📧 Email</button>';
    if(r.paymentId)acts+='<button onclick="admCp(\''+aE(r.paymentId)+'\',\'Payment ID\')" style="padding:5px 10px;background:rgba(246,188,104,0.1);border:1px solid rgba(246,188,104,0.2);color:#f6bc68;border-radius:6px;cursor:pointer;font-size:11px;">🔑 Pay ID</button>';
    if(r.mobile)acts+='<button onclick="admCp(\'+91'+aE(r.mobile)+'\',\'Mobile\')" style="padding:5px 10px;background:rgba(246,188,104,0.1);border:1px solid rgba(246,188,104,0.2);color:#f6bc68;border-radius:6px;cursor:pointer;font-size:11px;">📱 Mobile</button>';
    acts+='<button onclick="admCp(\''+aE(r.orderId)+'\',\'Ref\')" style="padding:5px 10px;background:rgba(246,188,104,0.1);border:1px solid rgba(246,188,104,0.2);color:#f6bc68;border-radius:6px;cursor:pointer;font-size:11px;">📋 Ref</button>';
    if(s&&r.invoiceNo){acts+='<button onclick="admDlInvoice(\''+aE(r.orderId)+'\')" style="padding:5px 10px;background:rgba(246,188,104,0.2);border:1px solid rgba(246,188,104,0.4);color:#f6bc68;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;">📄 GST Invoice</button>';}
    return '<div style="background:#0d1a30;border:1px solid rgba(246,188,104,0.1);border-radius:12px;padding:16px;margin-bottom:12px;">' +
      '<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">' +
        '<div><div style="font-weight:700;color:#f0e8d8;font-size:14px;">'+aH(r.name||'—')+'</div>' +
        '<div style="font-size:12px;color:rgba(212,196,178,0.6);">'+aH(r.email||'—')+(r.mobile?' · +91 '+aH(r.mobile):'')+'</div></div>' +
        '<span style="padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;background:rgba(0,0,0,0.3);color:'+badgeColor+';">'+badgeLabel+'</span>' +
      '</div>' +
      '<div style="font-size:12px;color:rgba(212,196,178,0.7);margin-bottom:4px;"><strong style="color:#f0e8d8;">'+aH(r.module||'—')+'</strong></div>' +
      '<div style="font-size:12px;color:rgba(212,196,178,0.7);">Total: <strong style="color:#f6bc68;">Rs.'+(r.totalAmt?Number(r.totalAmt).toFixed(2):Number(r.amount||0).toFixed(2))+'</strong>'+gstLine+'</div>' +
      (r.invoiceNo?'<div style="font-size:11px;color:#e8b86d;margin-top:4px;">Invoice: '+aH(r.invoiceNo)+'</div>':'')+
      '<div style="font-size:11px;color:rgba(212,196,178,0.45);margin-top:4px;">'+ft(r.confirmedAt||r.initiatedAt)+'</div>' +
      '<div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:10px;">'+acts+'</div>' +
    '</div>';
  }

  function admSync(st,lb){
    var d=document.getElementById('adot'),l=document.getElementById('aslbl');
    var c=st==='ok'?'#4ade80':st==='err'?'#f87171':'#f6bc68';
    if(d)d.style.background=c;if(l&&lb)l.textContent=lb;
  }
  function admCp(t,lb){navigator.clipboard.writeText(t).then(function(){admToast('📋 Copied '+lb);}).catch(function(){admToast(lb+': '+t);});}
  var _att;
  function admToast(m){var el=document.getElementById('adm-toast');if(!el)return;el.textContent=m;el.style.opacity='1';clearTimeout(_att);_att=setTimeout(function(){el.style.opacity='0';},2200);}

  function admDlInvoice(orderId){
    var rec=admRecs.find(function(x){return x.orderId===orderId;});
    if(!rec){admToast('Record not found.');return;}
    if(!rec.invoiceNo){admToast('Invoice data unavailable.');return;}
    try{
      var invData={invNo:rec.invoiceNo,invDate:rec.invDate||'—',dueDate:rec.dueDate||'—',name:rec.name,email:rec.email,mobile:rec.mobile||'',module:rec.module,baseAmt:rec.baseAmt||0,gstAmt:rec.gstAmt||0,totalAmt:rec.totalAmt||rec.amount||0,paymentId:rec.paymentId||'—',orderRef:rec.orderId};
      downloadInvoice(invData);admToast('📄 Invoice downloading…');
    }catch(e){console.error(e);admToast('Invoice generation failed.');}
  }

  /* ══════════════════════════════════════════════════════════════════════
     AUTO-OPEN FROM URL PARAM
  ══════════════════════════════════════════════════════════════════════ */
  (function(){
    var params=new URLSearchParams(window.location.search);
    var mod=params.get('module');
    if(mod){togglePay();document.getElementById('modSelect').value=mod;onModuleChange();}
  })();
</script>
{% endblock %}
