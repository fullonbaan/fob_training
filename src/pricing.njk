  /* ── Razorpay Launch (called from "Pay ₹X incl. GST" button) ────────── */
  window.goToStep3=function(){
    var name=document.getElementById('userName').value.trim(),
        email=document.getElementById('userEmail').value.trim(),
        mobileRaw=document.getElementById('mobile-number').value.replace(/[\s\-().]/g,'').trim(),
        mobileCode=(document.getElementById('cc-code').textContent||'+91').trim(),
        err=document.getElementById('fieldError');
    var mobile=mobileRaw.replace(/\D/g,'');
    if(!name){err.textContent='Please enter your full name.';return;}
    if(!email||!email.includes('@')){err.textContent='Please enter a valid email address.';return;}
    var minLen=mobileCode==='+91'?10:7;
    if(!mobile||mobile.length<minLen){err.textContent='Please enter a valid mobile number ('+(mobileCode==='+91'?'10 digits':'min 7 digits')+').';return;}
    err.textContent='';
    userData={name:name,email:email,mobile:mobile,mobileCode:mobileCode,mobileDisplay:mobileCode+' '+mobile};
    txnRef='FOBT'+Date.now();
    successFired=false; failureFired=false;

    // Fetch invoice number async before Razorpay opens
    genInvoiceNoGH().then(function(invNo){
      pendingInvNo=invNo;
      payInitiated(txnRef,userData,selDesc,selAmount,invNo);
    });

    // Google Ads: begin_checkout
    var activeCurr=selCurr||getActiveCurrency();
    if(typeof gtag!=='undefined'){gtag('event','begin_checkout',{value:selGD.total,currency:activeCurr,items:[{item_name:selDesc,price:selGD.total,quantity:1}]});}

    var rzpOptions={
      key: RZP_KEY_ID,
      amount: Math.round(selGD.total * 100),   // smallest unit: paise for INR, cents for USD/EUR
      currency: activeCurr,                     // ← correct currency flows to Razorpay
      name: 'FullOnBaan',
      description: selDesc,
      image: 'https://training.fullonbaan.com/og-image.png',
      prefill: {name:name, email:email, contact:mobile?(mobileCode+mobile):email},
      notes: {order_ref:txnRef, module:selDesc, currency:activeCurr, gst_amt:selGD.gst},
      theme: {color:'#A8782A'},
      handler: function(response){
        var payId=response.razorpay_payment_id;
        // Google Ads: conversion
        if(typeof gtag!=='undefined'){gtag('event','conversion',{send_to:'AW-18000254476/-yvYCLiW240cEIysmIdD',value:selGD.total,currency:activeCurr,transaction_id:txnRef});}
        onPaymentSuccess(payId);
      },
      modal:{
        ondismiss: function(){
          // User closed Razorpay without paying — return to step2 silently
          showStep('step2');
        }
      }
    };
    var rzp=new Razorpay(rzpOptions);
    rzp.on('payment.failed',function(response){
      console.warn('Razorpay payment failed:',response.error);
      onPaymentFailure(response.error);
    });
    showStep('step3');
    rzp.open();
  };

  /* ── Payment Success ──────────────────────────────────────────────────── */
  window.onPaymentSuccess=function(payId){
