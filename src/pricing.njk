<section class="py-20 px-4 sm:px-6 lg:px-8 bg-surface-container-low">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <span class="inline-flex items-center gap-2 bg-green-500/10 border border-green-500/30 text-green-400 text-xs font-bold font-label uppercase tracking-widest px-4 py-1.5 rounded-full mb-4 animate-pulse"><span class="w-2 h-2 bg-green-400 rounded-full"></span>Special Launch Price</span>
      <h1 class="sr-only">Infor LN Training Pricing — eBooks, Videos &amp; Bundle Packages</h1>
      <h2 class="text-4xl font-headline font-bold text-on-surface mb-4">Investment in Excellence</h2>
      <p class="text-on-surface-variant max-w-xl mx-auto">Transparent pricing for independent consultants and enterprise teams. All prices in INR (₹).</p>
    </div>

    <!-- PRICING — Premium Module Cards -->
    <style>
      /* === Premium Card Base === */
      .price-card {
        background: linear-gradient(160deg, #0d1a30 0%, #091326 40%, #0a1628 100%);
        border: 1px solid rgba(186,135,56,0.12);
        border-radius: 18px;
        padding: 28px 24px 24px;
        transition: border-color .4s cubic-bezier(0.22,1,0.36,1), transform .4s cubic-bezier(0.22,1,0.36,1), box-shadow .4s cubic-bezier(0.22,1,0.36,1);
        position: relative;
        overflow: hidden;
        cursor: pointer;
        will-change: transform;
      }
      /* Subtle inner glow */
      .price-card::after {
        content:'';
        position:absolute;
        top:-50%;
        left:-50%;
        width:200%;
        height:200%;
        background: radial-gradient(circle at 30% 20%, rgba(246,188,104,0.03) 0%, transparent 50%);
        pointer-events:none;
      }
      .price-card::before {
        content:'';
        position:absolute;
        top:0; left:0; right:0;
        height:2px;
        background: linear-gradient(90deg, transparent, #f6bc68, #ffd89e, #f6bc68, transparent);
        opacity:0;
        transition: opacity .4s;
      }
      .price-card:hover {
        border-color: rgba(246,188,104,0.3);
        transform: translateY(-5px);
        box-shadow:
          0 20px 50px rgba(0,0,0,.45),
          0 0 40px rgba(246,188,104,0.04),
          inset 0 1px 0 rgba(246,188,104,0.08);
      }
      .price-card:hover::before { opacity:1; }
      .price-card.selected {
        border-color: rgba(246,188,104,0.5);
        box-shadow: 0 0 0 1px rgba(246,188,104,0.2), 0 12px 32px rgba(0,0,0,.35), 0 0 60px rgba(246,188,104,0.06);
      }
      .price-card.selected::before { opacity:1; }

      /* === Card Interior === */
      .price-pill {
        display:inline-flex; align-items:center; gap:4px;
        font-size:9px; font-weight:700; padding:4px 12px;
        border-radius:20px; letter-spacing: 0.8px; text-transform: uppercase;
      }
      .price-tag {
        font-size:22px; font-weight:800;
        background: linear-gradient(135deg, #f6bc68 0%, #ffd89e 50%, #f6bc68 100%);
        -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
      }
      .mod-icon {
        width:42px; height:42px;
        display:flex; align-items:center; justify-content:center;
        border-radius:12px;
        background: linear-gradient(135deg, rgba(246,188,104,0.1) 0%, rgba(246,188,104,0.04) 100%);
        border: 1px solid rgba(246,188,104,0.1);
        flex-shrink:0;
      }
      .mod-icon .material-symbols-outlined { font-size:20px; color:#f6bc68; }
      .price-divider { height:1px; background: linear-gradient(90deg, transparent, rgba(246,188,104,0.15), transparent); margin: 14px 0 10px; }
      .price-row {
        display:flex; align-items:center; justify-content:space-between; gap:8px;
        padding:10px 12px; border-radius:10px;
        transition: all .25s ease;
      }
      .price-row + .price-row { margin-top:4px; }
      .price-row.clickable { cursor:pointer; }
      .price-row.clickable:hover {
        background: rgba(246,188,104,0.06);
        box-shadow: inset 0 0 0 1px rgba(246,188,104,0.08);
      }
      .price-label {
        font-family: 'Inter', sans-serif;
        font-size:11px; text-transform:uppercase; letter-spacing:1px; font-weight:600;
        color: rgba(212,196,178,0.7);
      }
      .price-val {
        font-family: 'Noto Serif', serif;
        font-weight:700; font-size:15px;
      }
      .combo-row {
        background: linear-gradient(135deg, rgba(246,188,104,0.08) 0%, rgba(246,188,104,0.02) 100%);
        border: 1px solid rgba(246,188,104,0.1);
        border-radius:12px;
        padding:12px 14px;
        margin-top:6px;
      }
      .combo-row:hover {
        background: linear-gradient(135deg, rgba(246,188,104,0.12) 0%, rgba(246,188,104,0.04) 100%);
        border-color: rgba(246,188,104,0.2);
      }

      /* === Bundle Cards === */
      .bundle-card {
        border-radius:20px; padding:32px; position:relative; overflow:hidden;
        transition: transform .4s cubic-bezier(0.22,1,0.36,1), box-shadow .4s cubic-bezier(0.22,1,0.36,1);
        cursor: pointer; will-change: transform;
      }
      .bundle-card::before {
        content:'';
        position:absolute; top:0; left:0; right:0; height:2px;
        background: linear-gradient(90deg, transparent, #f6bc68, #ffd89e, #f6bc68, transparent);
        opacity:0.6;
      }
      .bundle-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 24px 60px rgba(0,0,0,.5), 0 0 50px rgba(246,188,104,0.05);
      }
      .bundle-card.selected {
        box-shadow: 0 0 0 1px rgba(246,188,104,0.3), 0 24px 60px rgba(0,0,0,.5);
      }

      /* === Filter Tabs === */
      .filter-tab {
        padding: 10px 20px; border-radius: 12px; font-size: 12px; font-weight: 600;
        font-family: 'Inter', sans-serif; letter-spacing: 0.3px;
        border: 1px solid rgba(246,188,104,0.1); background: rgba(246,188,104,0.03);
        color: rgba(255,255,255,0.45); cursor: pointer;
        transition: color .3s, background .3s, border-color .3s, box-shadow .3s; white-space: nowrap;
      }
      .filter-tab:hover { color: rgba(255,255,255,0.75); border-color: rgba(246,188,104,0.25); background: rgba(246,188,104,0.06); }
      .filter-tab.active {
        background: linear-gradient(135deg, rgba(246,188,104,0.15) 0%, rgba(186,135,56,0.08) 100%);
        color: #f6bc68; border-color: rgba(246,188,104,0.3);
        box-shadow: 0 4px 16px rgba(246,188,104,0.1), inset 0 1px 0 rgba(246,188,104,0.1);
      }

      /* === Preview Links === */
      .preview-link {
        display: inline-flex; align-items: center; gap: 4px;
        font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.8px; text-decoration: none;
        padding: 6px 14px; border-radius: 20px;
        transition: all .3s cubic-bezier(0.22,1,0.36,1);
        flex-shrink: 0;
      }
      .preview-link .material-symbols-outlined { font-size: 14px; }
      .preview-link--gold {
        color: rgba(246,188,104,0.6);
        background: rgba(246,188,104,0.05);
        border: 1px solid rgba(246,188,104,0.1);
      }
      .preview-link--gold:hover {
        color: #f6bc68;
        background: rgba(246,188,104,0.1);
        border-color: rgba(246,188,104,0.3);
        box-shadow: 0 2px 12px rgba(246,188,104,0.1);
      }
      .preview-link--indigo {
        color: rgba(165,180,252,0.6);
        background: rgba(129,140,248,0.05);
        border: 1px solid rgba(129,140,248,0.1);
      }
      .preview-link--indigo:hover {
        color: #a5b4fc;
        background: rgba(129,140,248,0.1);
        border-color: rgba(129,140,248,0.3);
        box-shadow: 0 2px 12px rgba(129,140,248,0.1);
      }
      /* Light mode preview links */
      html.light .preview-link--gold { color: rgba(128,86,4,0.5); background: rgba(128,86,4,0.04); border-color: rgba(128,86,4,0.1); }
      html.light .preview-link--gold:hover { color: #805604; background: rgba(128,86,4,0.08); border-color: rgba(128,86,4,0.25); box-shadow: 0 2px 12px rgba(128,86,4,0.08); }
      html.light .preview-link--indigo { color: rgba(67,56,202,0.5); background: rgba(67,56,202,0.04); border-color: rgba(67,56,202,0.1); }
      html.light .preview-link--indigo:hover { color: #4338ca; background: rgba(67,56,202,0.08); border-color: rgba(67,56,202,0.25); box-shadow: 0 2px 12px rgba(67,56,202,0.08); }

      /* Smooth show/hide for cards */
      #pricingGrid .price-card { transition: all .4s cubic-bezier(0.22,1,0.36,1); }
      #bundleSection { transition: opacity .3s ease; }

      /* Card background image — static opacity, no transition on scroll */
      .price-card .card-bg-img { opacity: 0.15; }
      .price-card:hover .card-bg-img { opacity: 0.22; }
      html.light .price-card .card-bg-img { opacity: 0.06; }
      html.light .price-card:hover .card-bg-img { opacity: 0.09; }

      /* === Light Mode Overrides === */
      html.light .price-card { background: linear-gradient(160deg, #ffffff 0%, #faf8f5 40%, #f7f5f0 100%); border-color: #e8e2d8; }
      html.light .price-card::after { background: radial-gradient(circle at 30% 20%, rgba(128,86,4,0.03) 0%, transparent 50%); }
      html.light .price-card::before { background: linear-gradient(90deg, transparent, #805604, #a67206, #805604, transparent); }
      html.light .price-card:hover { border-color: rgba(128,86,4,0.35); box-shadow: 0 20px 50px rgba(0,0,0,.08), 0 0 40px rgba(128,86,4,0.03), inset 0 1px 0 rgba(128,86,4,0.06); }
      html.light .mod-icon { background: linear-gradient(135deg, rgba(128,86,4,0.08) 0%, rgba(128,86,4,0.03) 100%); border-color: rgba(128,86,4,0.1); }
      html.light .mod-icon .material-symbols-outlined { color: #805604; }
      html.light .price-tag { background: linear-gradient(135deg, #805604 0%, #a67206 50%, #805604 100%); -webkit-background-clip:text; background-clip:text; }
      html.light .price-divider { background: linear-gradient(90deg, transparent, rgba(128,86,4,0.12), transparent); }
      html.light .price-label { color: rgba(78,69,57,0.65); }
      html.light .price-row.clickable:hover { background: rgba(128,86,4,0.04); box-shadow: inset 0 0 0 1px rgba(128,86,4,0.06); }
      html.light .combo-row { background: linear-gradient(135deg, rgba(128,86,4,0.06) 0%, rgba(128,86,4,0.02) 100%); border-color: rgba(128,86,4,0.1); }
      html.light .combo-row:hover { background: linear-gradient(135deg, rgba(128,86,4,0.1) 0%, rgba(128,86,4,0.03) 100%); border-color: rgba(128,86,4,0.18); }
      html.light .bundle-card::before { background: linear-gradient(90deg, transparent, #805604, #a67206, #805604, transparent); }
      html.light .bundle-card:hover { box-shadow: 0 24px 60px rgba(0,0,0,.1), 0 0 50px rgba(128,86,4,0.04); }
      html.light .filter-tab { border-color: rgba(128,86,4,0.1); background: rgba(128,86,4,0.03); color: rgba(28,27,24,0.45); }
      html.light .filter-tab:hover { color: rgba(28,27,24,0.7); border-color: rgba(128,86,4,0.2); background: rgba(128,86,4,0.06); }
      html.light .filter-tab.active { background: linear-gradient(135deg, rgba(128,86,4,0.12) 0%, rgba(128,86,4,0.06) 100%); color: #805604; border-color: rgba(128,86,4,0.25); box-shadow: 0 4px 16px rgba(128,86,4,0.08); }
    </style>

    <!-- Filter Tabs -->
    <div class="flex flex-wrap gap-2 justify-center mb-10" id="pricingFilters">
      <button class="filter-tab active" onclick="filterPricing('all')">
        <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-sm">grid_view</span>All</span>
      </button>
      <button class="filter-tab" onclick="filterPricing('ebook')">
        <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-sm">menu_book</span>eBooks</span>
      </button>
      <button class="filter-tab" onclick="filterPricing('video')">
        <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-sm">play_circle</span>Video Courses</span>
      </button>
      <button class="filter-tab" onclick="filterPricing('combo')">
        <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-sm">star</span>Combo</span>
      </button>
      <button class="filter-tab" onclick="filterPricing('special')">
        <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-sm">auto_awesome</span>Special Edition</span>
      </button>
      <button class="filter-tab" onclick="filterPricing('bundle')">
        <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-sm">inventory_2</span>Bundles</span>
      </button>
    </div>

    <!-- ===== ALL CARDS IN A SINGLE GRID — filtered by JS ===== -->
    <div id="pricingGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">

      {# ---------- eBOOK CARDS (all 13 modules) ---------- #}
      {% set allEbooks = [
        { name: "Infor LN Development", icon: "code", key: "dev_ebook", price: "999", preview: "/preview/preview_Development.pdf", ebookCount: "73 eBooks", img: "https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=400&q=60" },
        { name: "Infor LN Administration", icon: "admin_panel_settings", key: "adm_ebook", price: "999", preview: "/preview/preview_Admin.pdf", ebookCount: "37 eBooks", img: "https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=400&q=60" },
        { name: "Infor LN Finance", icon: "account_balance", key: "fin_ebook", price: "999", preview: "/preview/preview_Finance.pdf", ebookCount: "41 eBooks", img: "https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?w=400&q=60" },
        { name: "Infor LN Manufacturing", icon: "precision_manufacturing", key: "mfg_ebook", price: "999", preview: "/preview/preview_Manufacturing.pdf", ebookCount: "10 eBooks", img: "https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?w=400&q=60" },
        { name: "Infor LN Logistics", icon: "local_shipping", key: "log_ebook", price: "999", preview: "/preview/preview_Logistics.pdf", ebookCount: "14 eBooks", img: "https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=400&q=60" },
        { name: "Infor LN Planning", icon: "event_note", key: "pln_ebook", price: "999", preview: "/preview/preview_Planning.pdf", ebookCount: "14 eBooks", img: "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=400&q=60" },
        { name: "Infor Extensibility", icon: "extension", key: "ext_ebook", price: "999", preview: "/preview/preview_Extensibility.pdf", ebookCount: "6 eBooks", img: "https://images.unsplash.com/photo-1518770660439-4636190af475?w=400&q=60" },
        { name: "Infor LN Warehousing", icon: "warehouse", key: "whs_ebook", price: "999", preview: "/preview/preview_Warehousing.pdf", ebookCount: "14 eBooks", img: "https://images.unsplash.com/photo-1553413077-190dd305871c?w=400&q=60" },
        { name: "Infor BOD", icon: "swap_horiz", key: "bod_ebook", price: "999", preview: "/preview/preview_BOD.pdf", ebookCount: "11 eBooks", img: "https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=400&q=60" },
        { name: "Infor ION", icon: "hub", key: "ion_ebook", price: "999", preview: "/preview/preview_ION.pdf", ebookCount: "15 eBooks", img: "https://images.unsplash.com/photo-1544197150-b99a580bb7a8?w=400&q=60" },
        { name: "Infor LN Multisite", icon: "language", key: "mst_ebook", price: "499", badge: "NEW", preview: "/preview/preview_Multisite.pdf", ebookCount: "5 eBooks", img: "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=400&q=60" },
        { name: "Finance Intercompany Setup", icon: "currency_exchange", key: "fin_intercompany", price: "499", badge: "NEW", preview: "/preview/preview_Finance_Intercompany.pdf", ebookCount: "1 eBook", img: "https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=400&q=60" },
        { name: "Financial Integration (LN 10.5)", icon: "integration_instructions", key: "fin_integration", price: "499", badge: "NEW", preview: "/preview/preview_Financial_Integration.pdf", ebookCount: "1 eBook", img: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=400&q=60" },
        { name: "Infor OS", icon: "cloud_circle", key: "infor_os", price: "1999", badge: "ON DEMAND", preview: "/preview/preview_Infor_OS.pdf", ebookCount: "11 eBooks", img: "https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=400&q=60" }
      ] %}
      {% for mod in allEbooks %}
      <div class="price-card" data-category="ebook" onclick="selectModule('{{ mod.key }}', event)">
        <!-- Faded module background image -->
        <img loading="lazy" aria-hidden="true" src="{{ mod.img }}" alt="" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:grayscale(100%);pointer-events:none;" class="card-bg-img">
        <div class="flex items-start justify-between mb-5" style="position:relative;z-index:1;">
          <div class="flex items-center gap-3.5">
            <div class="mod-icon">
              <span class="material-symbols-outlined">{{ mod.icon }}</span>
            </div>
            <h4 class="font-headline font-bold text-base text-on-surface leading-snug">{{ mod.name }}</h4>
          </div>
          {% if mod.badge %}
          <span class="price-pill" style="background:rgba(246,188,104,0.1);color:#f6bc68;border:1px solid rgba(246,188,104,0.15);">{{ mod.badge }}</span>
          {% endif %}
