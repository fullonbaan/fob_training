  function renderCCList(filter) {
    var ul = document.getElementById('cc-list');
    if (!ul) return;
    var q = (filter||'').toLowerCase();
    var list = q ? CC_DATA.filter(function(c){ return c.name.toLowerCase().indexOf(q)>=0 || c.code.indexOf(q)>=0; }) : CC_DATA;
    ul.innerHTML = list.map(function(c){
      return '<li><button type="button" onclick="selectCC(\''+c.iso+'\',\''+c.code+'\')"'+
        ' class="w-full flex items-center gap-3 px-4 py-2.5 hover:bg-primary/5 text-left transition-colors">'+
        '<span class="fi fi-'+c.iso+' rounded-sm" style="width:20px;height:15px;display:inline-block;"></span>'+
        '<span class="flex-1 text-xs text-on-surface">'+c.name+'</span>'+
        '<span class="text-xs text-on-surface-variant font-semibold">'+c.code+'</span>'+
        '</button></li>';
    }).join('');
  }

  window.selectCC = function(iso, code) {
    var flagEl = document.getElementById('cc-flag');
    if (flagEl) { flagEl.className = 'fi fi-'+iso+' rounded-sm'; flagEl.style.cssText = 'width:20px;height:15px;display:inline-block;'; }
    var codeEl = document.getElementById('cc-code');
    if (codeEl) codeEl.textContent = code;
    var dd = document.getElementById('cc-dropdown');
    if (dd) dd.classList.add('hidden');
    var numEl = document.getElementById('mobile-number');
    if (numEl) numEl.focus();
  };

  window.toggleCCDropdown = function() {
    var dd = document.getElementById('cc-dropdown');
    if (!dd) return;
    var isHidden = dd.classList.contains('hidden');
    dd.classList.toggle('hidden');
    if (isHidden) {
      renderCCList('');
      var srch = document.getElementById('cc-search');
      if (srch) { srch.value = ''; setTimeout(function(){ srch.focus(); }, 50); }
    }
  };

  window.filterCC = function(val) { renderCCList(val); };

