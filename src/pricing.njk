    currentInvData={invNo:invNo,invDate:invDate,dueDate:dueDate,name:userData.name,email:userData.email,mobile:userData.mobile||'',module:selDesc,baseAmt:selGD.base,gstAmt:selGD.gst,totalAmt:selGD.total,paymentId:payId,orderRef:txnRef};

