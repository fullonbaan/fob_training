    var lo=JSON.parse(localStorage.getItem('training_payments')||'[]');
    var i=lo.findIndex(function(x){return x.orderId===txnRefVal;});
    if(i>=0)lo[i]=Object.assign({},lo[i],rec);else lo.push(rec);
    localStorage.setItem('training_payments',JSON.stringify(lo));
    ghUpsert(rec);
  }

  /* ── Called after successful payment ────────────────────────────────── */
  function payConfirmed(txnRefVal, payId, invNo) {
