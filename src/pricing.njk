  var GST_RATE = 0.18;
  function calcGSTFromBase(basePrice) {
    var base  = Math.round(basePrice * 100) / 100;
    var gst   = Math.round(base * GST_RATE * 100) / 100;
    var total = Math.round((base + gst) * 100) / 100;
    return { base: base, gst: gst, total: total };
  }

